            animation: slideDown 0.3s ease;
        }

        @keyframes slideDown {
            from { transform: translateX(-50%) translateY(-20px); opacity: 0; }
            to { transform: translateX(-50%) translateY(0); opacity: 1; }
        }

        /* Скроллбар */
        ::-webkit-scrollbar {
            width: 6px;
        }

        ::-webkit-scrollbar-track {
            background: #1a1a2e;
        }

        ::-webkit-scrollbar-thumb {
            background: #3d3d5c;
            border-radius: 3px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: #667eea;
        }
    </style>
</head>
<body>
<!-- Верхняя панель -->
<div class="top-bar">
    <div class="user-info">
        <div class="user-avatar">🐹</div>
        <div class="user-details">
            <div class="username" id="top-username">Игрок</div>
            <div class="user-level">Lvl <span id="top-level">1</span></div>
        </div>
    </div>
    <div class="resources">
        <div class="resource energy">⚡ <span id="top-energy">250</span></div>
        <div class="resource gold">💰 <span id="top-gold">100</span></div>
    </div>
</div>

<!-- Основной контент -->
<div class="main-content">
    <!-- Лобби -->
    <div id="lobby-screen" class="screen active lobby-screen">
        <div class="castle-bg"></div>
        <div class="character-container">
            <div class="character" id="lobby-character">🐹</div>
        </div>

        <div class="stats-panel">
            <div class="stat-item">
                <div class="stat-icon">⚔️</div>
                <div class="stat-value" id="stat-attack">31</div>
                <div class="stat-label">Атака</div>
            </div>
            <div class="stat-item">
                <div class="stat-icon">💪</div>
                <div class="stat-value" id="stat-power">158</div>
                <div class="stat-label">Сила</div>
            </div>
            <div class="stat-item">
                <div class="stat-icon">❤️</div>
                <div class="stat-value" id="stat-hp">100</div>
                <div class="stat-label">HP</div>
            </div>
        </div>

        <button class="battle-button" onclick="showScreen('battle-select')">
            ⚔️ В БОЙ
        </button>
    </div>

    <!-- Создание персонажа -->
    <div id="create-screen" class="screen">
        <div class="form-container">
            <div class="form-title">🆕 Создание героя</div>
            <input type="text" id="name" placeholder="Имя персонажа" maxlength="30" />
            <select id="race">
                <option value="Человек">🧑 Человек</option>
                <option value="Эльф">🧝 Эльф</option>
                <option value="Орк">👹 Орк</option>
                <option value="Гном">🧔 Гном</option>
                <option value="Некромант">💀 Некромант</option>
            </select>
            <select id="class">
                <option value="Воин">⚔️ Воин</option>
                <option value="Маг">🔮 Маг</option>
                <option value="Лучник">🏹 Лучник</option>
                <option value="Вор">🎭 Вор</option>
                <option value="Жрец">🩸 Жрец</option>
                <option value="Паладин">🛡️ Паладин</option>
            </select>
            <button class="action-btn" onclick="createCharacter()">Создать героя</button>
        </div>
    </div>

    <!-- Выбор боя -->
    <div id="battle-select-screen" class="screen">
        <div class="form-container">
            <div class="form-title">⚔️ Выбор противника</div>
            <button class="action-btn" onclick="startBattle('Слизень', 1)">🦠 Слизень (Lvl 1)</button>
            <button class="action-btn" onclick="startBattle('Волк', 3)">🐺 Волк (Lvl 3)</button>
            <button class="action-btn" onclick="startBattle('Орк', 5)">👹 Орк (Lvl 5)</button>
            <button class="action-btn" onclick="startBattle('Дракон', 10)">🐉 Дракон (Lvl 10)</button>
            <button class="action-btn back-btn" onclick="showScreen('lobby')">← Назад</button>
        </div>
    </div>

    <!-- Бой -->
    <div id="battle-screen" class="screen">
        <div class="battle-arena">
            <div class="fighter">
                <div class="fighter-name">️ Ваш герой</div>
                <div class="hp-bar-container">
                    <div id="player-hp-bar" class="hp-bar player" style="width: 100%"></div>
                </div>
                <div class="hp-text"><span id="player-hp">100</span> / <span id="player-max-hp">100</span> HP</div>
            </div>

            <div class="fighter">
                <div class="fighter-name" id="monster-name">👹 Монстр</div>
                <div class="hp-bar-container">
                    <div id="monster-hp-bar" class="hp-bar enemy" style="width: 100%"></div>
                </div>
                <div class="hp-text"><span id="monster-hp">50</span> / <span id="monster-max-hp">50</span> HP</div>
            </div>

            <div class="battle-actions">
                <button class="action-btn" onclick="playerAttack()">⚔️ Атака</button>
                <button class="action-btn" id="potion-btn" onclick="useHealthPotion()">🧪 Зелье</button>
            </div>

            <div class="battle-log" id="battle-log"></div>
        </div>
    </div>

    <!-- Инвентарь -->
    <div id="inventory-screen" class="screen">
        <div class="form-container">
            <div class="form-title">🎒 Экипировка</div>
        </div>
        <div class="inventory-grid">
            <div class="equipment-slot" onclick="equipItem('weapon')">
                <div class="slot-icon">⚔️</div>
                <div class="slot-label">Оружие</div>
                <div class="slot-bonus" id="bonus-weapon">+0</div>
            </div>
            <div class="equipment-slot" onclick="equipItem('helmet')">
                <div class="slot-icon">🪖</div>
                <div class="slot-label">Шлем</div>
                <div class="slot-bonus" id="bonus-helmet">+0</div>
            </div>
            <div class="equipment-slot" onclick="equipItem('armor')">
                <div class="slot-icon">👕</div>
                <div class="slot-label">Броня</div>
                <div class="slot-bonus" id="bonus-armor">+0</div>
            </div>
            <div class="equipment-slot" onclick="equipItem('boots')">
                <div class="slot-icon">👢</div>
                <div class="slot-label">Сапоги</div>
                <div class="slot-bonus" id="bonus-boots">+0</div>
            </div>
            <div class="equipment-slot" onclick="equipItem('ring')">
                <div class="slot-icon">💍</div>
                <div class="slot-label">Кольцо</div>
                <div class="slot-bonus" id="bonus-ring">+0</div>
            </div>
            <div class="equipment-slot" onclick="equipItem('amulet')">
                <div class="slot-icon">📿</div>
                <div class="slot-label">Амулет</div>
                <div class="slot-bonus" id="bonus-amulet">+0</div>
            </div>
        </div>
        <div class="form-container" style="margin-top: 16px;">
            <div class="form-title">🎒 Предметы</div>
            <div id="inventory-items">
                <p style="text-align: center; color: #888; padding: 20px;">Инвентарь пуст</p>
            </div>
        </div>
    </div>

    <!-- Дерево навыков -->
    <div id="skill-tree-screen" class="screen">
        <div class="form-container">
            <div class="form-title">🌳 Дерево навыков</div>
            <div style="text-align: center; margin-bottom: 16px; color: #ffd700;">
                Очки навыков: <span id="skill-points">0</span>
            </div>
        </div>
        <div class="skill-tree">
            <div class="skill-row">
                <div class="skill-node unlocked" onclick="upgradeSkill('str')">
                    <div class="skill-icon">💪</div>
                    <div class="skill-bonus">+5</div>
                </div>
                <div class="skill-node unlocked" onclick="upgradeSkill('con')">
                    <div class="skill-icon">❤️</div>
                    <div class="skill-bonus">+14</div>
                </div>
                <div class="skill-node unlocked" onclick="upgradeSkill('dex')">
                    <div class="skill-icon">⚡</div>
                    <div class="skill-bonus">+2</div>
                </div>
            </div>
            <div class="skill-row">
                <div class="skill-node" onclick="upgradeSkill('str2')">
                    <div class="skill-icon">💀</div>
                    <div class="skill-bonus">+2%</div>
                </div>
                <div class="skill-node" onclick="upgradeSkill('con2')">
                    <div class="skill-icon">️</div>
                    <div class="skill-bonus">+15</div>
                </div>
                <div class="skill-node" onclick="upgradeSkill('dex2')">
                    <div class="skill-icon">🎯</div>
                    <div class="skill-bonus">+2</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Магазин -->
    <div id="shop-screen" class="screen">
        <div class="form-container">
            <div class="form-title">🛒 Магазин</div>
            <button class="action-btn" onclick="buyItem('health_potion')">🧪 Зелье здоровья (+50 HP)<br><small>100 💰</small></button>
            <button class="action-btn" onclick="buyItem('mana_potion')">⚡ Зелье маны (+30 MP)<br><small>80 💰</small></button>
            <button class="action-btn" onclick="buyItem('sword')">⚔️ Меч (+10 ATK)<br><small>500 💰</small></button>
            <button class="action-btn" onclick="buyItem('shield')">🛡️ Щит (+15 DEF)<br><small>450 💰</small></button>
        </div>
    </div>

    <!-- Профиль -->
    <div id="profile-screen" class="screen">
        <div class="form-container">
            <div class="form-title">👤 Профиль</div>
            <div style="text-align: center; margin: 20px 0;">
                <div style="font-size: 80px; margin-bottom: 10px;">🐹</div>
                <div style="font-size: 24px; font-weight: bold;" id="p-name">Игрок</div>
                <div style="color: #ffd700; margin-top: 8px;">Уровень <span id="p-level">1</span></div>
            </div>
            <div style="background: #1a1a2e; padding: 16px; border-radius: 12px; margin: 12px 0;">
                <div style="display: flex; justify-content: space-between; margin: 8px 0;">
                    <span>Опыт:</span>
                    <span id="p-exp">0 / 100</span>
                </div>
                <div style="display: flex; justify-content: space-between; margin: 8px 0;">
                    <span>Золото:</span>
                    <span id="p-gold" style="color: #ffd700;">100</span>
                </div>
                <div style="display: flex; justify-content: space-between; margin: 8px 0;">
                    <span>Побед:</span>
                    <span id="p-wins">0</span>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Нижняя навигация -->
<div class="bottom-nav">
    <div class="nav-item" onclick="showScreen('shop')">
        <div class="nav-icon">🏪</div>
        <div class="nav-label">Магазин</div>
    </div>
    <div class="nav-item" onclick="showScreen('inventory')">
        <div class="nav-icon">🎒</div>
        <div class="nav-label">Инвентарь</div>
    </div>
    <div class="nav-item active" onclick="showScreen('lobby')">
        <div class="nav-icon">⚔️</div>
        <div class="nav-label">Лобби</div>
    </div>
    <div class="nav-item" onclick="showScreen('skill-tree')">
        <div class="nav-icon">🌳</div>
        <div class="nav-label">Навыки</div>
    </div>
    <div class="nav-item" onclick="showScreen('profile')">
        <div class="nav-icon">🏆</div>
        <div class="nav-label">Профиль</div>
    </div>
</div>

<script>
    const tg = Telegram.WebApp;
    tg.expand();
    tg.ready();

    // Глобальные переменные
    let playerData = {
        name: 'Игрок',
        level: 1,
        exp: 0,
        gold: 100,
        energy: 250,
        attack: 31,
        power: 158,
        hp: 100,
        maxHp: 100,
        inventory: {},
        equipment: {},
        skillPoints: 0
    };

    let battleState = null;

    // Навигация
    function showScreen(screenId) {
        // Скрываем все экраны
        document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));

        // Показываем нужный
        const targetScreen = document.getElementById(screenId + '-screen');
        if (targetScreen) {
            targetScreen.classList.add('active');
        }

        // Обновляем активную кнопку навигации
        document.querySelectorAll('.nav-item').forEach(item => {
            item.classList.remove('active');
        });

        // Находим соответствующую кнопку (упрощённо)
        const navMap = {
            'lobby': 2,
            'inventory': 1,
            'skill-tree': 3,
            'shop': 0,
            'profile': 4
        };

        if (navMap[screenId] !== undefined) {
            document.querySelectorAll('.nav-item')[navMap[screenId]].classList.add('active');
        }

        // Загружаем данные если нужно
        if (screenId === 'profile') loadPlayer();
        if (screenId === 'inventory') loadInventory();
        if (screenId === 'lobby') updateLobby();
    }

    // Обновление лобби
    function updateLobby() {
        document.getElementById('stat-attack').textContent = playerData.attack;
        document.getElementById('stat-power').textContent = playerData.power;
        document.getElementById('stat-hp').textContent = playerData.hp;
        updateTopBar();
    }

    // Обновление верхней панели
    function updateTopBar() {
        document.getElementById('top-username').textContent = playerData.name;
        document.getElementById('top-level').textContent = playerData.level;
        document.getElementById('top-energy').textContent = playerData.energy;
        document.getElementById('top-gold').textContent = playerData.gold;
    }

    // Toast уведомления
    function showToast(message) {
        const existing = document.querySelector('.toast');
        if (existing) existing.remove();

        const toast = document.createElement('div');
        toast.className = 'toast';
        toast.textContent = message;
        document.body.appendChild(toast);
        setTimeout(() => toast.remove(), 3000);
    }

    // Создание персонажа
    async function createCharacter() {
        const name = document.getElementById("name").value.trim();
        const race = document.getElementById("race").value;
        const cls = document.getElementById("class").value;

        if (name.length < 3) {
            showToast("Имя должно быть от 3 символов");
            return;
        }

        const baseAttrs = {
            "Воин": { str: 8, con: 10, dex: 6, int: 4 },
            "Маг": { str: 4, con: 5, dex: 6, int: 10 },
            "Лучник": { str: 6, con: 6, dex: 10, int: 6 },
            "Вор": { str: 5, con: 5, dex: 12, int: 6 },
            "Жрец": { str: 5, con: 7, dex: 6, int: 9 },
            "Паладин": { str: 9, con: 9, dex: 5, int: 7 }
        };

        playerData.name = name;
        playerData.attack = baseAttrs[cls].str * 3;
        playerData.power = baseAttrs[cls].con * 10;
        playerData.maxHp = baseAttrs[cls].con * 10;
        playerData.hp = playerData.maxHp;

        showToast(`Герой ${name} создан!`);
        updateTopBar();
        updateLobby();
        showScreen('lobby');
    }

    // Загрузка игрока
    async function loadPlayer() {
        document.getElementById('p-name').textContent = playerData.name;
        document.getElementById('p-level').textContent = playerData.level;
        document.getElementById('p-exp').textContent = `${playerData.exp} / ${playerData.level * 100}`;
        document.getElementById('p-gold').textContent = playerData.gold;
    }

    // Инвентарь
    async function loadInventory() {
        const container = document.getElementById('inventory-items');
        if (Object.keys(playerData.inventory).length === 0) {
            container.innerHTML = '<p style="text-align: center; color: #888; padding: 20px;">Инвентарь пуст</p>';
        } else {
            container.innerHTML = '';
            for (const [item, count] of Object.entries(playerData.inventory)) {
                const div = document.createElement('div');
                div.style.cssText = 'background: #1a1a2e; padding: 12px; margin: 8px 0; border-radius: 8px; display: flex; justify-content: space-between; align-items: center;';
                div.innerHTML = `
                    <span>${getItemName(item)} ×${count}</span>
                    <button onclick="useItem('${item}')" style="background: #667eea; border: none; color: white; padding: 6px 12px; border-radius: 6px; cursor: pointer;">Использовать</button>
                `;
                container.appendChild(div);
            }
        }
    }

    function getItemName(item) {
        const names = {
            'health_potion': '🧪 Зелье здоровья',
            'mana_potion': '⚡ Зелье маны',
            'sword': '⚔️ Меч',
            'shield': '🛡️ Щит'
        };
        return names[item] || item;
    }

    async function useItem(item) {
        if (item === 'health_potion') {
            playerData.hp = Math.min(playerData.maxHp, playerData.hp + 50);
            playerData.inventory[item]--;
            if (playerData.inventory[item] <= 0) delete playerData.inventory[item];
            showToast('HP восстановлено!');
            updateLobby();
            loadInventory();
        }
    }

    function equipItem(slot) {
        showToast('Слот экипировки: ' + slot);
    }

    // Боевая система
    function startBattle(monsterName, level) {
        battleState = {
            monster: {
                name: monsterName,
                level,
                hp: level * 20,
                maxHp: level * 20,
                attack: Math.floor(level * 3 + Math.random() * 5)
            },
            player: {
                hp: playerData.hp,
                maxHp: playerData.maxHp,
                attack: playerData.attack
            }
        };

        document.getElementById('monster-name').textContent = `👹 ${monsterName} (Lvl ${level})`;
        document.getElementById('monster-hp').textContent = battleState.monster.hp;
        document.getElementById('monster-max-hp').textContent = battleState.monster.maxHp;
        document.getElementById('monster-hp-bar').style.width = '100%';

        document.getElementById('player-hp').textContent = battleState.player.hp;
        document.getElementById('player-max-hp').textContent = battleState.player.maxHp;
        document.getElementById('player-hp-bar').style.width = '100%';

        document.getElementById('battle-log').innerHTML = '';
        logBattle(`⚔️ Бой начался! Вы против ${monsterName} (ур. ${level})`);

        updatePotionButton();
        showScreen('battle');
    }

    function logBattle(text) {
        const log = document.getElementById('battle-log');
        const entry = document.createElement('div');
        entry.className = 'log-entry';
        entry.textContent = text;
        log.appendChild(entry);
        log.scrollTop = log.scrollHeight;
    }

    function playerAttack() {
        if (!battleState) return;

        const damage = Math.floor(battleState.player.attack * (0.8 + Math.random() * 0.4));
        battleState.monster.hp = Math.max(0, battleState.monster.hp - damage);

        updateMonsterHP();
        logBattle(`💥 Вы нанесли ${damage} урона!`);

        if (battleState.monster.hp <= 0) {
            setTimeout(() => endBattle(true), 500);
            return;
        }

        setTimeout(monsterAttack, 800);
    }

    function monsterAttack() {
        if (!battleState) return;

        const damage = Math.floor(battleState.monster.attack * (0.8 + Math.random() * 0.4));
        battleState.player.hp = Math.max(0, battleState.player.hp - damage);

        updatePlayerHP();
        logBattle(`🩸 ${battleState.monster.name} наносит ${damage} урона!`);

        if (battleState.player.hp <= 0) {
            setTimeout(() => endBattle(false), 500);
        }
    }

    function updateMonsterHP() {
        const { hp, maxHp } = battleState.monster;
        document.getElementById('monster-hp').textContent = hp;
        document.getElementById('monster-hp-bar').style.width = `${(hp / maxHp) * 100}%`;
    }

    function updatePlayerHP() {
        const { hp, maxHp } = battleState.player;
        document.getElementById('player-hp').textContent = hp;
        document.getElementById('player-hp-bar').style.width = `${(hp / maxHp) * 100}%`;
        playerData.hp = hp;
    }

    function updatePotionButton() {
        const potionBtn = document.getElementById('potion-btn');
        const hasPotion = playerData.inventory['health_potion'] > 0;
        potionBtn.disabled = !hasPotion;
        potionBtn.style.opacity = hasPotion ? '1' : '0.5';
    }

    function useHealthPotion() {
        if (battleState.player.hp >= battleState.player.maxHp) {
            showToast("HP полон!");
            return;
        }
        if (!playerData.inventory['health_potion']) {
            showToast("Нет зелий!");
            return;
        }

        battleState.player.hp = Math.min(battleState.player.maxHp, battleState.player.hp + 50);
        updatePlayerHP();
        playerData.inventory['health_potion']--;
        logBattle("💚 Вы использовали зелье здоровья!");
        updatePotionButton();
    }

    async function endBattle(win) {
        if (win) {
            const expReward = battleState.monster.level * 50;
            const goldReward = battleState.monster.level * 30;

            playerData.exp += expReward;
            playerData.gold += goldReward;

            // Level up check
            if (playerData.exp >= playerData.level * 100) {
                playerData.level++;
                playerData.exp = 0;
                playerData.maxHp += 20;
                playerData.hp = playerData.maxHp;
                playerData.attack += 5;
                showToast(`🎉 Уровень повышен! Теперь ${playerData.level}!`);
            } else {
                showToast(`🏆 Победа! +${expReward} XP, +${goldReward} 💰`);
            }

            logBattle(`✅ Победа! Получено ${expReward} опыта и ${goldReward} золота.`);
        } else {
            logBattle("💀 Вы проиграли...");
            showToast("Поражение...");
        }

        setTimeout(() => {
            updateTopBar();
            updateLobby();
            showScreen('lobby');
        }, 2000);
    }

    // Магазин
    function buyItem(item) {
        const prices = {
            'health_potion': 100,
            'mana_potion': 80,
            'sword': 500,
            'shield': 450
        };

        if (playerData.gold >= prices[item]) {
            playerData.gold -= prices[item];
            playerData.inventory[item] = (playerData.inventory[item] || 0) + 1;
            showToast(`Куплено: ${getItemName(item)}`);
            updateTopBar();
        } else {
            showToast("Недостаточно золота!");
        }
    }

    // Навыки
    function upgradeSkill(skill) {
        if (playerData.skillPoints > 0) {
            playerData.skillPoints--;
            showToast(`Навык ${skill} улучшен!`);
            document.getElementById('skill-points').textContent = playerData.skillPoints;
        } else {
            showToast("Нет очков навыков!");
        }
    }

    // Инициализация
    window.addEventListener('load', () => {
        updateTopBar();
        updateLobby();

        // Проверяем Telegram WebApp
        if (tg.initDataUnsafe?.user) {
            const user = tg.initDataUnsafe.user;
            playerData.name = user.first_name || 'Игрок';
            updateTopBar();
        }
    });
</script>
